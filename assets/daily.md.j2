{#- ==================== 其他信息（others tier） ==================== -#}
{#- 公共宏：单行渲染，复用在 demoted / fresh / stale 三子组 -#}
{% macro render_others_row(row) -%}
{%- set vm = row.get("value_mapped") or {} -%}
{%- set title = row.get("title_zh_others") or vm.get("title_zh") or row.get("primary_title") or row.get("title") or "—" -%}
{%- set url = row.get("primary_url") -%}
{%- set title_cell = ("[" ~ (title | replace("|", "\\|") | replace("[", "(") | replace("]", ")")) ~ "](" ~ url ~ ")") if url else (title | replace("|", "\\|")) -%}
{%- set cc = vm.get("core_content") or [] -%}
{%- set raw_gist = row.get("primary_gist") or "" -%}
{%- set gist_src = row.get("gist_zh_others") or (cc[0] if cc else raw_gist) or "" -%}
{%- set gist = (gist_src | replace("|", "\\|") | replace("\n", " ") | truncate(100, end="…")) -%}
{%- set note_parts = [] -%}
{%- if row.get("tier_adjusted_reason") or row.get("auto_demoted_reason") -%}{%- set _ = note_parts.append("⬇️ 原 " ~ row.get("original_tier_label", row.original_tier) ~ " 降级") -%}{%- endif -%}
{%- if row.get("auto_demoted_reason") -%}{%- set _ = note_parts.append("⚠️ " ~ row.get("auto_demoted_reason_label", row.auto_demoted_reason)) -%}{%- endif -%}
{%- if row.get("is_stale") -%}{%- set _ = note_parts.append("🕒 过窗") -%}{%- endif -%}
{%- if (row.get("spam_confidence") or 0) >= 0.6 -%}{%- set _ = note_parts.append("⚠️ 疑似水文") -%}{%- endif -%}
{%- if row.get("is_followup") -%}{%- set _ = note_parts.append("📎 续报") -%}{%- endif -%}
| {{ row.get("primary_source_name", "—") | replace("|", "\\|") }} | {{ title_cell }} | {{ gist or "—" }} | {{ note_parts | join(" · ") or "—" }} |
